# ShadowRep AI Backend — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Slack Webhook URL (optional — alerts will log-only if not set)
SLACK_WEBHOOK_URL=

# Database path (SQLite, relative to backend/)
DATABASE_URL=./shadowrep.db

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Agent scheduler tick interval in seconds
AGENT_TICK_INTERVAL=5
